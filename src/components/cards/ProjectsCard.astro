---
import BentoCard from '../BentoCard.astro';
import projectData from '../../data/projects.json';
import siteData from '../../data/site.json';
const { projects } = projectData;
const { labels } = siteData;

interface Props { delayIndex?: number; }
const { delayIndex } = Astro.props;
---
<BentoCard delayIndex={delayIndex} className="projects-card">
  {labels.projects && labels.projects.trim() !== "" && (
    <h2 class="section-title" id="projects">{labels.projects}</h2>
  )}
  <div class="projects-list">
    {projects.map(project => (
      <div class="project-item">
        {project.icon && (
          <div class="icon" aria-hidden="true">
            {project.icon}
          </div>
        )}
        <div class="project-content">
          <div class="project-header">
            <div class="title-wrapper">
              <h3 class="project-title">{project.title}</h3>
              <div class="tags">
                {project.tags.map(tag => (
                  <span class="tag text-mono" style={`background: ${tag.bg}; color: ${tag.text};`}>{tag.name}</span>
                ))}
              </div>
            </div>
          </div>
          <p class="project-description text-secondary">{project.description}</p>
          <div class="project-links">
            {project.links.map(link => (
              <a href={link.url} target="_blank" rel="noopener noreferrer" class="project-link text-mono text-secondary">
                <i class="fas fa-external-link-alt"></i> {link.name}
              </a>
            ))}
          </div>
        </div>
      </div>
    ))}
  </div>
</BentoCard>

<style>
  .projects-list { display: flex; flex-direction: column; gap: 32px; }
  .project-item {
    display: flex; gap: 16px; align-items: center;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--border-color);
    transition: opacity 0.15s ease-in-out;
  }
  .project-item:hover { opacity: 0.9; }
  .project-item:last-child { border-bottom: none; padding-bottom: 0; }
  
  .icon {
    font-size: 1.75rem;
    display: flex; align-items: center; justify-content: center;
    width: 56px; height: 56px; background: var(--bg-app);
    border-radius: 14px; flex-shrink: 0;
  }

  .project-content { flex: 1; display: flex; flex-direction: column; gap: 6px; }
  
  .project-header { display: flex; align-items: center; margin-bottom: 4px; }
  .title-wrapper { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
  .project-title { font-size: 1.125rem; font-weight: 700; margin: 0; color: var(--text-primary); }
  
  .tags { display: flex; gap: 8px; }
  .tag { font-size: 0.75rem; padding: 4px 10px; border-radius: 999px; font-weight: 500; }
  
  .project-description { font-size: 0.9375rem; margin: 0; line-height: 1.5; color: var(--text-secondary); }
  
  .project-links { 
    display: flex; 
    gap: 16px; 
    margin-top: 4px; 
  }
  
  .project-link { 
    font-size: 0.75rem; 
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 6px;
    transition: all 0.2s ease;
    padding: 2px 0;
  }
  
  .project-link:hover { 
    color: var(--text-primary, #000); 
    opacity: 1;
  }

  .project-link i {
    font-size: 0.65rem;
    opacity: 0.6;
  }
</style>
