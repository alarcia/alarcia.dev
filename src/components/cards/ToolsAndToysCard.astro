---
import BentoCard from '../BentoCard.astro';
import projectData from '../../data/projects.json';
import siteData from '../../data/site.json';
const { toolsAndToys } = projectData;
const { labels } = siteData;

interface Props { delayIndex?: number; }
const { delayIndex } = Astro.props;
---
<BentoCard delayIndex={delayIndex} className="tools-toys-card">
  {labels.toolsAndToys && labels.toolsAndToys.trim() !== "" && (
    <h2 class="section-title">{labels.toolsAndToys}</h2>
  )}
  <div class="list">
    {toolsAndToys.map(item => (
      <div class="item">
        {item.icon && (
          <div class="icon" aria-hidden="true">{item.icon}</div>
        )}
        <div class="info">
          <div class="header">
            <h3 class="title">{item.title}</h3>
            {item.type && <span class={`badge ${item.type}`}>{item.type}</span>}
          </div>
          <p class="description text-secondary">{item.description}</p>
          {item.links && item.links.length > 0 && (
            <div class="links">
              {item.links.map(link => (
                <a href={link.url} target="_blank" rel="noopener noreferrer" class="link-badge text-mono">
                  {link.name}
                </a>
              ))}
            </div>
          )}
        </div>
      </div>
    ))}
  </div>
</BentoCard>

<style>
  .list { display: flex; flex-direction: column; gap: 24px; }
  .item {
    display: flex; gap: 16px; align-items: center;
    transition: opacity 0.15s ease-in-out;
  }
  .item:hover { opacity: 0.9; }

  .icon {
    font-size: 1.5rem;
    display: flex; align-items: center; justify-content: center;
    width: 48px; height: 48px; background: var(--bg-app);
    border-radius: 12px; flex-shrink: 0;
  }
  
  .header { display: flex; align-items: center; gap: 8px; margin-bottom: 2px; padding-top: 2px; }
  .title { font-size: 1rem; font-weight: 700; margin: 0; }
  .description { font-size: 0.875rem; margin: 0; line-height: 1.4; }
  
  .links { 
    display: flex; 
    gap: 8px; 
    margin-top: 8px; 
  }
  
  .link-badge {
    font-size: 0.75rem;
    text-decoration: none;
    font-weight: 500;
    padding: 4px 10px;
    border-radius: 999px;
    background: #dbeafe;
    color: #1e40af;
    transition: background-color 0.2s ease;
  }
  
  .link-badge:hover { 
    background: #bfdbfe;
  }

  .badge {
    font-size: 0.65rem; text-transform: uppercase; font-weight: 700;
    padding: 2px 6px; border-radius: 4px; letter-spacing: 0.02em;
  }
  .badge.toy { background: #fee2e2; color: #991b1b; }
  .badge.tool { background: #f3f4f6; color: #374151; }
</style>
