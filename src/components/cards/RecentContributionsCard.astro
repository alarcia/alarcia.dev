---
import BentoCard from '../BentoCard.astro';
import projectData from '../../data/projects.json';
import siteData from '../../data/site.json';
const { recentContributions } = projectData;
const { labels } = siteData;

interface Props { delayIndex?: number; }
const { delayIndex } = Astro.props;
---
<BentoCard delayIndex={delayIndex} className="recent-contributions">
  {labels.recentContributions && labels.recentContributions.trim() !== "" && (
    <h2 class="section-title">{labels.recentContributions}</h2>
  )}
  <ul class="timeline">
    {recentContributions.map(contrib => (
      <li class="timeline-item">
        <div class="icon" aria-hidden="true">{contrib.icon}</div>
        <div class="details">
          <div class="details-header">
            <span class="project-name">{contrib.project}</span>
            <span class="time text-secondary text-mono">{contrib.time}</span>
          </div>
          <div class="links">
            {contrib.links.map(link => (
              <a href={link.url} target="_blank" rel="noopener noreferrer" class="link-badge text-mono">
                {link.name}
              </a>
            ))}
          </div>
        </div>
      </li>
    ))}
  </ul>
</BentoCard>

<style>
  .timeline {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 24px;
  }
  .timeline-item {
    display: flex; gap: 16px; align-items: center;
  }
  .icon {
    font-size: 1.5rem;
    display: flex; align-items: center; justify-content: center;
    width: 48px; height: 48px; background: var(--bg-app);
    border-radius: 12px; flex-shrink: 0;
  }
  .details {
    display: flex; flex-direction: column; width: 100%;
  }
  .details-header { display: flex; justify-content: space-between; align-items: baseline; gap: 8px; }
  .project-name { font-weight: 500; color: var(--text-primary); }
  .time { font-size: 0.75rem; }
  
  .links { display: flex; gap: 8px; margin-top: 6px; }
  
  .link-badge {
    font-size: 0.75rem;
    text-decoration: none;
    font-weight: 500;
    padding: 2px 10px;
    border-radius: 999px;
    background: #dbeafe;
    color: #1e40af;
    transition: background-color 0.2s ease;
  }
  
  .link-badge:hover { 
    background: #bfdbfe;
  }
</style>
