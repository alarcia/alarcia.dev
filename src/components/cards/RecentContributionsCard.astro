---
import BentoCard from '../BentoCard.astro';
import siteData from '../../data/site.json';

const { labels } = siteData;

interface Props { delayIndex?: number; }
const { delayIndex } = Astro.props;

let recentCommits: any[] = [];

try {
  const headers: HeadersInit = { 'User-Agent': 'alarcia.dev-portfolio' };
  
  // Use a GitHub token if available to avoid rate limits during development
  if (import.meta.env.GITHUB_TOKEN) {
    headers['Authorization'] = `Bearer ${import.meta.env.GITHUB_TOKEN}`;
  }

  // Fetch public events from your GitHub account
  const response = await fetch('https://api.github.com/users/alarcia/events/public', { headers });
  
  if (response.ok) {
    const events = await response.json();
    
    // Filter out only PushEvents (commits)
    const pushes = events.filter((e: any) => e.type === 'PushEvent');
    
    const emojis = ['🚀', '✨', '🔥', '💻', '🛠️', '⚡️', '🌟', '🔮', '🔨'];
    
    // Get unique repositories from the latest pushes, up to 4
    const uniqueRepos = new Set();
    for (const event of pushes) {
      if (!uniqueRepos.has(event.repo.name) && recentCommits.length < 4) {
        uniqueRepos.add(event.repo.name);
        const randomIcon = emojis[Math.floor(Math.random() * emojis.length)];
        recentCommits.push({
          project: event.repo.name,
          time: event.created_at,
          url: `https://github.com/${event.repo.name}`,
          icon: randomIcon
        });
      }
    }
  } else if (response.status === 403) {
    console.warn("GitHub API rate limit exceeded. Showing cached/fallback data.");
    // Fallback data when rate limited (very common during 'npm run dev' hot reloads)
    recentCommits = [
      { project: "alarcia/alarcia.dev", time: new Date().toISOString(), url: "https://github.com/alarcia/alarcia.dev", icon: '🚀' },
      { project: "alarcia/illa-notifier", time: new Date(Date.now() - 86400000).toISOString(), url: "https://github.com/alarcia/illa-notifier", icon: '🔥' }
    ];
  }
} catch (e) {
  console.error("Error fetching GitHub events", e);
}
---
<BentoCard delayIndex={delayIndex} className="recent-contributions">
  {labels.recentActivity && labels.recentActivity.trim() !== "" && (
    <h2 class="section-title">{labels.recentActivity}</h2>
  )}
  <ul class="timeline">
    {recentCommits.length > 0 ? recentCommits.map(contrib => (
      <li class="timeline-item">
        <div class="icon" aria-hidden="true">{contrib.icon}</div>
        <div class="details">
          <div class="details-header">
            <a href={contrib.url} target="_blank" rel="noopener noreferrer" class="project-name-link">
              {contrib.project.split('/')[1] || contrib.project}
            </a>
            <span class="time text-secondary text-mono relative-time" data-date={contrib.time}>
              {new Date(contrib.time).toLocaleDateString()}
            </span>
          </div>
        </div>
      </li>
    )) : (
      <li class="timeline-item">
        <div class="details">
          <span class="text-secondary text-mono">No recent activity found.</span>
        </div>
      </li>
    )}
  </ul>
</BentoCard>

<script>
  // Format dates relative to now on the client side to avoid build-time freezing
  const rtf = new Intl.RelativeTimeFormat('en', { numeric: 'auto' });
  
  document.querySelectorAll('.relative-time').forEach(el => {
    const dateStr = el.getAttribute('data-date');
    if (dateStr) {
      const date = new Date(dateStr);
      const now = new Date();
      const diffMs = date.getTime() - now.getTime();
      const diffDays = Math.round(diffMs / (1000 * 60 * 60 * 24));
      
      if (diffDays === 0) {
        const diffHours = Math.round(diffMs / (1000 * 60 * 60));
        if (diffHours === 0) {
          const diffMins = Math.round(diffMs / (1000 * 60));
          el.textContent = rtf.format(diffMins, 'minute');
        } else {
          el.textContent = rtf.format(diffHours, 'hour');
        }
      } else {
        el.textContent = rtf.format(diffDays, 'day');
      }
    }
  });
</script>

<style>
  .timeline {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 24px;
  }
  .timeline-item {
    display: flex; gap: 16px; align-items: center;
  }
  .icon {
    font-size: 1.5rem;
    display: flex; align-items: center; justify-content: center;
    width: 48px; height: 48px; background: var(--bg-app);
    border-radius: 12px; flex-shrink: 0;
  }
  .details {
    display: flex; flex-direction: column; width: 100%;
  }
  .details-header { display: flex; justify-content: space-between; align-items: baseline; gap: 8px; }
  
  .project-name-link { 
    font-weight: 500; 
    color: var(--text-primary); 
    text-decoration: none;
    transition: color 0.2s ease;
  }
  
  .project-name-link:hover {
    color: #3b82f6;
  }
  
  .time { font-size: 0.75rem; }
</style>
