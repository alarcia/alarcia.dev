---
import BentoCard from "../BentoCard.astro";
import siteData from "../../data/site.json";

const { labels, status: fallbackStatus, statusSource } = siteData;

const gistOwner = statusSource?.gistOwner?.trim() ?? "";
const gistId = statusSource?.gistId?.trim() ?? "";
const gistFileName = statusSource?.gistFileName?.trim() ?? "";
const gistRawUrl =
  gistOwner && gistId && gistFileName
    ? `https://gist.githubusercontent.com/${gistOwner}/${gistId}/raw/${gistFileName}`
    : "";

const fallbackTags = Array.isArray(fallbackStatus?.tags)
  ? fallbackStatus.tags
  : [];

interface Props {
  delayIndex?: number;
}
const { delayIndex } = Astro.props;
---

<BentoCard delayIndex={delayIndex} className="status-card">
  {
    labels.status && labels.status.trim() !== "" && (
      <h2 class="section-title" id="status">
        {labels.status}
      </h2>
    )
  }
  <div class="status-content">
    <p class="status-text text-primary" data-status-text>{fallbackStatus.text}</p>
    <div
      class={`status-tags${fallbackTags.length === 0 ? " is-empty" : ""}`}
      data-status-tags
    >
      {fallbackTags.map((tag) => (
        <span
          class="tag text-mono"
          style={`background: ${tag.bg}; color: ${tag.text};`}
        >
          {tag.name}
        </span>
      ))}
    </div>
  </div>
</BentoCard>

<script define:vars={{ gistRawUrl }}>
  const textElement = document.querySelector(".status-card [data-status-text]");
  const tagsContainer = document.querySelector(".status-card [data-status-tags]");

  const isValidHexColor = (value) =>
    typeof value === "string" && /^#([A-Fa-f0-9]{3}|[A-Fa-f0-9]{6})$/.test(value);

  const normalizeStatusTag = (tag) => {
    if (!tag || typeof tag !== "object") return null;
    if (typeof tag.name !== "string" || tag.name.trim() === "") return null;

    return {
      name: tag.name.trim(),
      bg: isValidHexColor(tag.bg) ? tag.bg : "#E5E7EB",
      text: isValidHexColor(tag.text) ? tag.text : "#111827",
    };
  };

  const normalizeStatusPayload = (payload) => {
    if (!payload || typeof payload !== "object") return null;
    if (typeof payload.text !== "string" || payload.text.trim() === "") return null;

    const tags = Array.isArray(payload.tags)
      ? payload.tags.map(normalizeStatusTag).filter(Boolean)
      : [];

    return {
      text: payload.text.trim(),
      tags,
    };
  };

  const renderTags = (tags) => {
    while (tagsContainer.firstChild) {
      tagsContainer.removeChild(tagsContainer.firstChild);
    }

    if (tags.length === 0) {
      tagsContainer.classList.add("is-empty");
      return;
    }

    tagsContainer.classList.remove("is-empty");
    const fragment = document.createDocumentFragment();

    tags.forEach((tag) => {
      const chip = document.createElement("span");
      chip.className = "tag text-mono";
      chip.style.background = tag.bg;
      chip.style.color = tag.text;
      chip.textContent = tag.name;
      fragment.appendChild(chip);
    });

    tagsContainer.appendChild(fragment);
  };

  const fetchStatusFromGist = async () => {
    if (!textElement || !tagsContainer || !gistRawUrl) return;

    const url = new URL(gistRawUrl);
    // Force a fresh read on every page load for this dynamic status payload.
    url.searchParams.set("_", Date.now().toString());

    const controller = new AbortController();
    const timeoutId = window.setTimeout(() => controller.abort(), 3500);

    try {
      const response = await fetch(url.toString(), {
        signal: controller.signal,
        cache: "no-store",
        headers: {
          Accept: "application/json",
          "Cache-Control": "no-cache, no-store, max-age=0",
          Pragma: "no-cache",
        },
      });

      if (!response.ok) return;

      const payload = await response.json();
      const normalizedStatus = normalizeStatusPayload(payload);

      if (!normalizedStatus) return;

      textElement.textContent = normalizedStatus.text;
      renderTags(normalizedStatus.tags);
    } catch {
      // Keep local fallback rendered on the server.
    } finally {
      window.clearTimeout(timeoutId);
    }
  };

  fetchStatusFromGist();
</script>

<style>
  .status-content {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding-top: 8px;
  }

  .status-icon {
    color: var(--text-secondary);
    opacity: 0.8;
  }

  .status-text {
    font-size: 1.125rem;
    line-height: 1.6;
    font-weight: 500;
    margin: 0;
    font-style: italic;
  }

  .status-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 8px;
  }

  .status-tags.is-empty {
    display: none;
  }

  .status-tags :global(.tag) {
    font-size: 0.75rem;
    padding: 6px 12px;
    border-radius: 999px;
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    border: 1px solid rgba(0, 0, 0, 0.05);
  }
</style>
