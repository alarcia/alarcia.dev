---
import BentoCard from "../BentoCard.astro";
import siteData from "../../data/site.json";

const { labels } = siteData;
const username = "alarcia";

// Fetch GitHub Stats with fallbacks
let githubStats = {
  contributions: "100",
  repositories: "10",
};

try {
  const [userRes, contribRes] = await Promise.all([
    fetch(`https://api.github.com/users/${username}`),
    fetch(`https://github-contributions-api.deno.dev/${username}.json`),
  ]);

  if (userRes.ok) {
    const userData = await userRes.json();
    githubStats.repositories = userData.public_repos;
  }

  if (contribRes.ok) {
    const contribData = await contribRes.json();
    githubStats.contributions = contribData.totalContributions;
  }
} catch (e) {
  console.error("Error fetching GitHub stats:", e);
}

interface Props {
  delayIndex?: number;
}
const { delayIndex } = Astro.props;
---

<BentoCard delayIndex={delayIndex} className="github-activity">
  {
    labels.githubActivity && labels.githubActivity.trim() !== "" && (
      <h2 class="section-title" id="activity">
        {labels.githubActivity}
      </h2>
    )
  }

  <div class="activity-graph-container">
    <a
      href={siteData.contact.github}
      target="_blank"
      rel="noopener noreferrer"
      class="activity-link"
    >
      <img
        src="https://ghchart.rshah.org/40c463/alarcia"
        alt="GitHub Contributions for alarcia"
        class="activity-chart"
        loading="lazy"
        width="600"
        height="100"
      />
    </a>
  </div>

  <div class="stats-grid">
    <div class="stat-item">
      <span class="stat-value text-mono">{githubStats.contributions}</span>
      <span class="stat-label text-secondary">Contributions</span>
    </div>
    <div class="stat-item">
      <span class="stat-value text-mono">{githubStats.repositories}</span>
      <span class="stat-label text-secondary">Repositories</span>
    </div>
  </div>
</BentoCard>

<style>
  .activity-graph-container {
    width: 100%;
    background-color: transparent;
    border-radius: 8px;
    overflow: hidden;
    aspect-ratio: 2 / 1;
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }
  .activity-link {
    display: flex;
    width: 100%;
    height: 100%;
    justify-content: flex-end;
    align-items: center;
    text-decoration: none;
  }

  .activity-chart {
    height: 100%;
    width: auto;
    object-fit: cover;
    object-position: -25px -25px;
    filter: saturate(0.9);
    transition: filter 0.3s ease;
  }

  .activity-chart:hover {
    filter: saturate(1.1);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }
  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .stat-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-primary);
  }
  .stat-label {
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Responsive adjustments */
  @media (max-width: 640px) {
    .stat-value {
      font-size: 1.25rem;
    }
  }
</style>
